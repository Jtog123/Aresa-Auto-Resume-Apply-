{
  "manifest_version": 3,
  "name": "Resume Agent",
  "version": "1.0.0",
  "description": "Resume autocomplete assistant for job applications",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/index.js"]
    }
  ],
  "background": {
    "service_worker": "dist/background/index.js"
  },
  "action": {
    "default_popup": "dist/popup/index.html",
    "default_title": "Resume Agent"
  }
}
